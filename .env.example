# ── Gemini (primary LLM) ──────────────────────────────────────────────────────
# Add up to 9 keys. Agent rotates to the next on quota/rate-limit errors.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ── Anthropic (fallback LLM) ──────────────────────────────────────────────────
# Used automatically if all Gemini keys are exhausted.
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_2=
